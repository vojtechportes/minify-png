{
  "name": "minify-png",
  "version": "0.1.0",
  "description": "Node.js PNG minification library with edge-aware flat-region optimization and photo-safe palette recompression.",
  "license": "MIT",
  "author": {
    "name": "Vojtěch Porteš",
    "email": "vojtech.v.portes@gmail.com"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "minify-png": "./dist/minify-png.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "png",
    "minify",
    "compress",
    "optimization",
    "quantization",
    "posterization",
    "image",
    "node",
    "typescript",
    "sharp"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "benchmark:wikimedia": "tsx benchmark/index.ts",
    "build": "tsdown",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "format": "prettier --write . --ignore-unknown",
    "lint": "eslint .",
    "prepare": "husky",
    "test:png": "tsx test/index.ts",
    "test:png:pngquant": "tsx test/index.ts --pngquant",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{json,md}": [
      "prettier --write"
    ],
    "*.{js,mjs,cjs,ts}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "pngjs": "^7.0.0"
  },
  "optionalDependencies": {
    "sharp": "^0.34.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.3",
    "dotenv": "^17.4.2",
    "eslint": "^9.25.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.1",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.2",
    "tsdown": "^0.12.9",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1"
  }
}
